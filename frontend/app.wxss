/* 全局样式 */
page {
  --primary-color: #667eea;
  --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --secondary-color: #764ba2;
  --success-color: #52c41a;
  --warning-color: #ffa502;
  --error-color: #ff4757;
  --text-color: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --bg-color: #f5f5f5;
  --bg-white: #ffffff;
  --border-color: #eeeeee;
  --shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);

  font-size: 28rpx;
  color: var(--text-color);
  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 容器 */
.container {
  min-height: 100vh;
  background-color: var(--bg-color);
}

/* 卡片 */
.card {
  background-color: var(--bg-white);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: var(--shadow);
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary {
  background: var(--primary-gradient);
  color: #ffffff;
}

.btn-primary-outline {
  background-color: transparent;
  border: 2rpx solid var(--primary-color);
  color: var(--primary-color);
}

.btn-default {
  background-color: #f5f5f5;
  color: var(--text-color);
}

/* 输入框 */
.input {
  height: 88rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.input-border {
  border: 2rpx solid var(--border-color);
  background-color: var(--bg-white);
}

/* Flex布局 */
.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mt-40 { margin-top: 40rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.mb-40 { margin-bottom: 40rpx; }
.ml-10 { margin-left: 10rpx; }
.ml-20 { margin-left: 20rpx; }
.mr-10 { margin-right: 10rpx; }
.mr-20 { margin-right: 20rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 文字 */
.text-primary { color: var(--primary-color); }
.text-secondary { color: var(--text-secondary); }
.text-light { color: var(--text-light); }
.text-success { color: var(--success-color); }
.text-warning { color: var(--warning-color); }
.text-error { color: var(--error-color); }
.text-center { text-align: center; }
.text-bold { font-weight: bold; }
.text-lg { font-size: 36rpx; }
.text-xl { font-size: 40rpx; }
.text-xxl { font-size: 48rpx; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state .icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-state .text {
  color: var(--text-light);
  font-size: 28rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 30rpx 0;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
}

.avatar-xl {
  width: 160rpx;
  height: 160rpx;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-primary {
  background-color: rgba(102, 126, 234, 0.1);
  color: var(--primary-color);
}

.tag-success {
  background-color: rgba(82, 196, 26, 0.1);
  color: var(--success-color);
}

/* 渐变背景 */
.bg-gradient {
  background: var(--primary-gradient);
}

/* 阴影 */
.shadow {
  box-shadow: var(--shadow);
}

/* 圆角 */
.radius { border-radius: 16rpx; }
.radius-lg { border-radius: 24rpx; }
.radius-xl { border-radius: 32rpx; }