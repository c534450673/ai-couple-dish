/* pages/couple-home/couple-home.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
}

/* 头部区域 */
.header-section {
  position: relative;
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.1) 0%, transparent 100%);
}

.heart-icon {
  position: absolute;
  top: 30rpx;
  right: 40rpx;
  font-size: 40rpx;
  opacity: 0.5;
}

/* 头像 */
.avatar-section {
  position: relative;
  margin-bottom: 30rpx;
}

.avatar-wrapper {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
}

.avatar.left {
  margin-right: -20rpx;
}

.avatar.right {
  margin-left: -20rpx;
}

.avatar-heart {
  font-size: 48rpx;
  margin: 0 10rpx;
  animation: heartbeat 1.5s infinite;
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

/* 昵称 */
.nicknames {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.separator {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin: 0 15rpx;
}

/* 恋爱天数 */
.love-days {
  display: flex;
  align-items: baseline;
  background: rgba(255, 255, 255, 0.2);
  padding: 20rpx 50rpx;
  border-radius: 50rpx;
  margin-bottom: 20rpx;
}

.days-number {
  font-size: 72rpx;
  font-weight: bold;
  color: #ffffff;
}

.days-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 10rpx;
}

.timer-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-left: 20rpx;
}

/* 下一个纪念日 */
.next-anniversary {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  padding: 16rpx 30rpx;
  border-radius: 30rpx;
}

.anniversary-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.anniversary-name {
  font-size: 26rpx;
  color: #ffffff;
  margin-right: 15rpx;
}

.anniversary-days {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 功能菜单 */
.menu-grid {
  display: flex;
  flex-wrap: wrap;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 30rpx 20rpx;
  margin-top: 40rpx;
}

.menu-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  position: relative;
}

.menu-icon {
  font-size: 56rpx;
  margin-bottom: 10rpx;
}

.menu-text {
  font-size: 24rpx;
  color: #666;
}

.menu-count {
  position: absolute;
  top: 10rpx;
  right: 15rpx;
  background: #ff4757;
  color: #ffffff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
}

.feed-badge {
  position: absolute;
  top: 10rpx;
  right: 15rpx;
  width: 16rpx;
  height: 16rpx;
  background: #ff4757;
  border-radius: 50%;
}

/* 最近动态 */
.recent-section {
  background: #ffffff;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-item {
  display: flex;
  align-items: center;
}

.activity-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.activity-info {
  flex: 1;
}

.activity-title {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.activity-time {
  font-size: 22rpx;
  color: #999;
}

/* 空状态提示 */
.empty-hint {
  background: #ffffff;
  padding: 60rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hint-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.hint-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.hint-btn {
  width: 300rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  color: #ffffff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hint-btn::after {
  border: none;
}

/* 解绑入口 */
.unbind-section {
  background: #ffffff;
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: center;
}

.unbind-section text {
  font-size: 24rpx;
  color: #999;
}