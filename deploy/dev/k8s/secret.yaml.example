# Development Environment - Secrets Template
# ============================================
# ⚠️  DO NOT COMMIT ACTUAL SECRETS TO VERSION CONTROL
# ============================================
#
# This file is a template showing the required secret keys.
# Actual secrets should be created using one of these methods:
#
# Method 1: kubectl command (recommended for dev)
#   kubectl create secret generic ai-couple-dish-secrets \
#     --from-literal=DB_PASSWORD='your_dev_db_password' \
#     --from-literal=REDIS_PASSWORD='your_dev_redis_password' \
#     --from-literal=JWT_SECRET='your_dev_jwt_secret_at_least_32_chars' \
#     --from-literal=WX_APPID='your_dev_wx_appid' \
#     --from-literal=WX_SECRET='your_dev_wx_secret' \
#     -n ai-couple-dish-dev
#
# Method 2: Use sealed-secrets for GitOps workflow
#   Kubeseal the template and commit the encrypted version
#
# Method 3: External secrets operator with Vault
#   Configure external-secrets to fetch from your secret manager
#
apiVersion: v1
kind: Secret
metadata:
  name: ai-couple-dish-secrets
  namespace: ai-couple-dish-dev
type: Opaque
stringData:
  # Database password
  DB_PASSWORD: "REPLACE_WITH_YOUR_DEV_DB_PASSWORD"
  # Redis password
  REDIS_PASSWORD: "REPLACE_WITH_YOUR_DEV_REDIS_PASSWORD"
  # JWT secret (minimum 32 characters for development)
  JWT_SECRET: "REPLACE_WITH_YOUR_DEV_JWT_SECRET_AT_LEAST_32_CHARS"
  # WeChat MiniApp AppID (dev environment)
  WX_APPID: "REPLACE_WITH_YOUR_DEV_WX_APPID"
  # WeChat MiniApp Secret (dev environment)
  WX_SECRET: "REPLACE_WITH_YOUR_DEV_WX_SECRET"
