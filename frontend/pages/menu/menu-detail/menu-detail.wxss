/* pages/menu/menu-detail/menu-detail.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.menu-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-image {
  width: 100%;
  height: 400rpx;
}

.menu-content {
  padding: 30rpx;
}

.menu-header {
  margin-bottom: 20rpx;
}

.menu-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.menu-tags {
  display: flex;
  gap: 10rpx;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.tag-type {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.tag-status {
  background: rgba(118, 75, 162, 0.1);
  color: #764ba2;
}

.menu-info-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-label {
  color: #999;
  font-size: 28rpx;
  width: 140rpx;
}

.info-value {
  color: #333;
  font-size: 28rpx;
  flex: 1;
}

.menu-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-edit, .btn-delete {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-edit {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.btn-delete {
  background: #f5f5f5;
  color: #666;
}

.loading, .empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}