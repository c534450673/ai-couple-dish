<!--pages/note/note-list/note-list.wxml-->
<view class="container">
  <view class="header">
    <text class="title">美食笔记</text>
    <view class="add-btn" bindtap="onAddNote">+ 添加</view>
  </view>

  <view class="note-list" wx:if="{{notes.length > 0}}">
    <view
      class="note-card"
      wx:for="{{notes}}"
      wx:key="id"
      bindtap="onViewNote"
      data-id="{{item.id}}"
    >
      <view class="note-content">
        <text class="note-title">{{item.title}}</text>
        <text class="note-text">{{item.content}}</text>
        <view class="note-images" wx:if="{{item.images && item.images.length > 0}}">
          <image wx:for="{{item.images}}" wx:for-item="img" src="{{img}}" mode="aspectFill"/>
        </view>
        <text class="note-date">{{item.createTime}}</text>
      </view>
      <view class="note-actions">
        <text class="delete-btn" catchtap="onDeleteNote" data-id="{{item.id}}">删除</text>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && notes.length === 0}}">
    <text>还没有笔记</text>
    <text class="empty-hint">记录你们的美食故事</text>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>