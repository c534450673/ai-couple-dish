<!--pages/note/note-add/note-add.wxml-->
<view class="container">
  <view class="section">
    <text class="section-title">标题</text>
    <input
      class="input"
      placeholder="给笔记起个标题"
      value="{{title}}"
      bindinput="onTitleInput"
      maxlength="50"
    />
  </view>

  <view class="section">
    <text class="section-title">内容</text>
    <textarea
      class="textarea"
      placeholder="记录你们的美食故事..."
      value="{{content}}"
      bindinput="onContentInput"
      maxlength="2000"
    />
  </view>

  <view class="section">
    <text class="section-title">图片</text>
    <view class="image-grid">
      <view
        class="image-item"
        wx:for="{{images}}"
        wx:key="index"
      >
        <image src="{{item}}" mode="aspectFill"/>
        <view class="remove-btn" bindtap="onRemoveImage" data-index="{{index}}">×</view>
      </view>
      <view class="add-image" bindtap="onChooseImage" wx:if="{{images.length < 9}}">
        <text class="add-icon">+</text>
        <text class="add-text">添加图片</text>
      </view>
    </view>
  </view>

  <view class="bottom-section">
    <button class="btn-save" bindtap="onSave" loading="{{loading}}">
      保存
    </button>
  </view>
</view>