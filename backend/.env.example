# =============================================
# Backend - Environment Variables Template
# =============================================
# Copy to .env and configure for your environment
# =============================================

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_couple_dish
DB_USERNAME=root
DB_PASSWORD=your_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DATABASE=0

# JWT (IMPORTANT: Use a strong secret in production!)
JWT_SECRET=your_jwt_secret_at_least_64_characters_long
JWT_EXPIRATION=604800000

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Server
SERVER_PORT=8080

# CORS
CORS_ORIGINS=*

# Logging
LOG_LEVEL=debug
LOG_LEVEL_SPRING=info
