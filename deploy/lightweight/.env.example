# 情侣私密菜单 - Web版部署环境变量配置
# 复制此文件为 .env 并修改配置

#==========================================
# 项目基础配置
#==========================================
PROJECT_NAME=ai-couple-dish

#==========================================
# MySQL 配置
#==========================================
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=ai_couple_dish
MYSQL_USER=aicoupledish
MYSQL_PASSWORD=your_mysql_password_here

#==========================================
# Redis 配置
#==========================================
REDIS_PASSWORD=your_redis_password_here

#==========================================
# JWT 配置
#==========================================
# 生产环境必须修改! 生成命令: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=your_jwt_secret_at_least_32_characters_long_change_me

#==========================================
# 文件上传配置
#==========================================
FILE_UPLOAD_PATH=/app/uploads
# 修改为你的域名
FILE_BASE_URL=http://your-domain.com/api/uploads
