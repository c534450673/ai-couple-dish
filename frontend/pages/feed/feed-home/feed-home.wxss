/* pages/feed/feed-home/feed-home.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 今日投喂区域 */
.today-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
}

.section-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 10rpx;
}

.section-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.today-status {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.status-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  padding: 30rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-card.received {
  background: rgba(255, 82, 82, 0.3);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.status-card.sent {
  background: rgba(82, 196, 26, 0.3);
}

.status-icon {
  font-size: 56rpx;
  margin-bottom: 10rpx;
}

.status-text {
  font-size: 24rpx;
  color: #ffffff;
}

.btn-send {
  width: 100%;
  height: 96rpx;
  background: #ffffff;
  border-radius: 48rpx;
  color: #667eea;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-send::after {
  border: none;
}

.btn-send[disabled] {
  background: rgba(255, 255, 255, 0.5);
  color: #999;
}

/* 投喂列表区域 */
.feed-section {
  padding: 30rpx;
}

.feed-section .section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.feed-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.feed-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.feed-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.sender-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.sender-info {
  flex: 1;
}

.sender-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.feed-time {
  font-size: 22rpx;
  color: #999;
}

.feed-type {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
}

.feed-type.tag-meal {
  background: rgba(255, 149, 0, 0.1);
  color: #ff9500;
}

.feed-type.tag-dessert {
  background: rgba(255, 59, 48, 0.1);
  color: #ff3b30;
}

.feed-type.tag-snack {
  background: rgba(255, 204, 0, 0.1);
  color: #ffcc00;
}

.feed-type.tag-drink {
  background: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.feed-content {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
}

.feed-actions {
  display: flex;
  gap: 20rpx;
}

.btn-accept, .btn-reject {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-accept {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.btn-reject {
  background: #f5f5f5;
  color: #666;
}

.btn-accept::after, .btn-reject::after {
  border: none;
}

.feed-status {
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}