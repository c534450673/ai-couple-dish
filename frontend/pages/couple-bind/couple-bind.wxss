/* pages/couple-bind/couple-bind.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
}

/* 顶部 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.header-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 模式选择 */
.mode-select {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
}

.mode-card {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.mode-card:last-child {
  border-bottom: none;
}

.mode-card:active {
  background: #f9f9f9;
}

.mode-icon {
  font-size: 56rpx;
  margin-right: 30rpx;
}

.mode-info {
  flex: 1;
}

.mode-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.mode-desc {
  font-size: 24rpx;
  color: #999;
}

.mode-arrow {
  font-size: 48rpx;
  color: #ccc;
}

/* 模式内容 */
.mode-content {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
}

.back-btn {
  color: #667eea;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

/* 日期选择 */
.date-section, .input-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.date-picker {
  height: 96rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.placeholder {
  color: #999;
}

/* 按钮 */
.btn-generate, .btn-bind {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 48rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-generate[disabled], .btn-bind[disabled] {
  background: #ccc;
}

/* 情侣码展示 */
.code-display {
  margin-top: 60rpx;
  text-align: center;
}

.code-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
}

.code-box {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.code-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 8rpx;
}

.code-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-bottom: 20rpx;
}

.btn-copy, .btn-share {
  width: 200rpx;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #667eea;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-copy::after, .btn-share::after {
  border: none;
}

.code-tip {
  font-size: 24rpx;
  color: #999;
}

/* 输入框 */
.code-input {
  height: 120rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 40rpx;
  text-align: center;
  letter-spacing: 8rpx;
  font-weight: bold;
}